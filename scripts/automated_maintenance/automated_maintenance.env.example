# luthien-proxy automated maintenance config.
# Copy to automated_maintenance.env (gitignored) and edit. Loaded by lib/config.sh.
# Values here override defaults; anything left unset uses the defaults
# documented in lib/config.sh.

# --- Repo ---
# Where the maintenance job clones/pulls luthien-proxy. Independent of your
# dev checkout so the two never tangle.
# MAINT_REPO_URL="https://github.com/LuthienResearch/luthien-proxy.git"
# MAINT_REPO_BRANCH="main"

# --- State ---
# Root for runs/, public/, repo/. Must be writable by the user the
# scheduler runs as. Default: $HOME/.luthien/automated_maintenance
# MAINT_STATE_DIR="$HOME/.luthien/automated_maintenance"

# --- What to run ---
# Comma-separated. Available: dev_checks, e2e_sqlite, e2e_mock, e2e_real, doc_drift
# Default (from lib/config.sh) omits e2e_real because it costs money and
# needs Docker + ANTHROPIC_API_KEY. Uncomment + edit to override.
# MAINT_CHECKS="dev_checks,e2e_sqlite,e2e_mock,e2e_real,doc_drift"

# Per-check timeouts in seconds. 0 = no timeout.
MAINT_TIMEOUT_DEV_CHECKS=1800
MAINT_TIMEOUT_E2E=3600
MAINT_TIMEOUT_DOC_DRIFT=900

# --- Autofix (opt-in, risky) ---
# When true, on any failure spawns a headless `claude` session that tries
# to fix it and opens a draft PR. Requires `claude` CLI and `gh` authenticated.
AUTOFIX_ENABLED=false
AUTOFIX_TIMEOUT=1800
# Hard dollar cap on API spend per autofix attempt.
AUTOFIX_MAX_BUDGET_USD=5
# Branch prefix for autofix PRs.
AUTOFIX_BRANCH_PREFIX="maint-fix"

# --- Secrets ---
# Required for e2e_real. Leave unset if you don't run that tier.
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Dashboard ---
# Where to write the static HTML dashboard. Point your web server here.
# Default: $MAINT_STATE_DIR/public
# MAINT_PUBLIC_DIR="$HOME/.luthien/automated_maintenance/public"

# How many runs to keep on disk and in the dashboard. Older runs are pruned.
MAINT_RUN_RETENTION=30

# --- Notifications (optional) ---
# If set, POST a one-line summary to this URL on completion (Slack incoming
# webhook, ntfy, custom endpoint). Empty = disabled.
# MAINT_WEBHOOK_URL=""
