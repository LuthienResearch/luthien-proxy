# Local development without Docker
# Copy to .env: cp .env.local.example .env
#
# Or skip this entirely and use: uv run python -m luthien_proxy.main --local

# --local flag uses ~/.luthien/local.db automatically; override here if needed
DATABASE_URL=sqlite:///~/.luthien/local.db
REDIS_URL=
POLICY_CONFIG=config/policy_config.yaml
POLICY_SOURCE=file
PROXY_API_KEY=sk-local-dev
ADMIN_API_KEY=sk-local-dev

# Optional: set your Anthropic API key to proxy real requests
# ANTHROPIC_API_KEY=sk-ant-...
