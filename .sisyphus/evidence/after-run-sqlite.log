                conn.execute(f"DROP INDEX IF EXISTS {idx}")
    
            # Pass 1: conversation_calls (FK parent) — must precede events.
            calls_batch: list[tuple] = []
            for session_idx, (session_id, n_calls) in enumerate(plan):
                if n_calls > biggest:
